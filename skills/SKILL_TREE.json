{
  "$schema_version": 1,
  "registry_type": "skill-tree-sidecar",
  "purpose": "Human-maintained taxonomy and classification aid for the local OpenCode skill library. This file does not modify or override any existing skill definition.",
  "guarantees": {
    "read_only_against_existing_skills": true,
    "modifies_existing_skill_files": false,
    "deletes_existing_skill_files": false
  },
  "taxonomy": {
    "build": {
      "label": "Build",
      "summary": "Implementation-oriented engineering skills for application, platform, data, and architecture work.",
      "category_bias": [
        "deep",
        "ultrabrain"
      ],
      "subtrees": {
        "frontend-ui": {
          "summary": "Frontend patterns, design systems, accessibility, and UI implementation.",
          "skill_examples": [
            "frontend-patterns",
            "frontend-design",
            "design-system",
            "accessibility",
            "click-path-audit"
          ]
        },
        "backend-api": {
          "summary": "Backend architecture, APIs, services, and integration patterns.",
          "skill_examples": [
            "backend-patterns",
            "api-design",
            "api-connector-builder",
            "fullstack-dev",
            "nestjs-patterns"
          ]
        },
        "data-db": {
          "summary": "Database schema, migrations, queries, and datastore-specific patterns.",
          "skill_examples": [
            "database-migrations",
            "postgres",
            "postgres-patterns",
            "mssql-server",
            "clickhouse-io"
          ]
        },
        "mobile": {
          "summary": "iOS, Android, Flutter, React Native, and cross-platform application patterns.",
          "skill_examples": [
            "android-clean-architecture",
            "android-native-dev",
            "ios-application-dev",
            "flutter-dev",
            "react-native-dev"
          ]
        },
        "language-framework": {
          "summary": "Language- and framework-specific conventions and patterns.",
          "skill_examples": [
            "python-patterns",
            "golang-patterns",
            "rust-patterns",
            "kotlin-patterns",
            "springboot-patterns"
          ]
        },
        "architecture": {
          "summary": "Requirements, product capability shaping, and architectural decision support.",
          "skill_examples": [
            "requirements",
            "requirements-clarity",
            "product-capability",
            "product-lens",
            "hexagonal-architecture"
          ]
        }
      }
    },
    "verify": {
      "label": "Verify",
      "summary": "Testing, verification, review, and quality gates.",
      "category_bias": [
        "deep",
        "quick"
      ],
      "subtrees": {
        "testing": {
          "summary": "Test strategy, TDD, and framework-specific testing guidance.",
          "skill_examples": [
            "testing",
            "tdd-workflow",
            "python-testing",
            "golang-testing",
            "e2e-testing"
          ]
        },
        "verification": {
          "summary": "Build, lint, typecheck, and release-readiness verification.",
          "skill_examples": [
            "verification",
            "verification-loop",
            "benchmark",
            "browser-qa",
            "canary-watch"
          ]
        },
        "review": {
          "summary": "Code review, architecture review, and onboarding-quality analysis.",
          "skill_examples": [
            "code-review",
            "code-review-expert",
            "codebase-onboarding",
            "code-tour",
            "repo-scan"
          ]
        }
      }
    },
    "secure": {
      "label": "Secure",
      "summary": "Application, infrastructure, and domain-specific security and compliance work.",
      "category_bias": [
        "deep",
        "ultrabrain"
      ],
      "subtrees": {
        "application-security": {
          "summary": "Cross-stack application security review and implementation guidance.",
          "skill_examples": [
            "security",
            "security-review",
            "security-scan",
            "security-bounty-hunter",
            "safety-guard"
          ]
        },
        "framework-security": {
          "summary": "Framework-specific security best practices.",
          "skill_examples": [
            "django-security",
            "laravel-security",
            "springboot-security",
            "perl-security",
            "hipaa-compliance"
          ]
        },
        "specialized-security": {
          "summary": "Specialized domain security such as healthcare and web3.",
          "skill_examples": [
            "healthcare-phi-compliance",
            "healthcare-eval-harness",
            "defi-amm-security",
            "llm-trading-agent-security",
            "evm-token-decimals"
          ]
        }
      }
    },
    "research": {
      "label": "Research",
      "summary": "Search, documentation lookup, evidence gathering, and current-state analysis.",
      "category_bias": [
        "deep",
        "quick"
      ],
      "subtrees": {
        "search-docs": {
          "summary": "Internal/external search and documentation retrieval.",
          "skill_examples": [
            "search",
            "search-first",
            "documentation-lookup",
            "exa-search",
            "deep-research"
          ]
        },
        "analysis": {
          "summary": "Research workflows for market, product, and operational analysis.",
          "skill_examples": [
            "research-ops",
            "market-research",
            "lead-intelligence",
            "knowledge-ops",
            "iterative-retrieval"
          ]
