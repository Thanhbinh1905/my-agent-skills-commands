            "eval-harness",
            "skill-comply",
            "santa-method"
          ]
        },
        "memory-context": {
          "summary": "Context, knowledge, and continuous learning support for agents.",
          "skill_examples": [
            "continuous-learning",
            "continuous-learning-v2",
            "context-budget",
            "strategic-compact",
            "agent-sort"
          ]
        }
      }
    },
    "create": {
      "label": "Create",
      "summary": "Writing, document generation, design, media, and presentation output.",
      "category_bias": [
        "writing",
        "artistry",
        "visual-engineering"
      ],
      "subtrees": {
        "writing": {
          "summary": "Long-form writing, content systems, voice, and prompt shaping.",
          "skill_examples": [
            "article-writing",
            "brand-voice",
            "content-engine",
            "crosspost",
            "prompt-optimizer"
          ]
        },
        "documents": {
          "summary": "Structured document and presentation generation.",
          "skill_examples": [
            "minimax-docx",
            "minimax-pdf",
            "minimax-xlsx",
            "pptx-generator",
            "nutrient-document-processing"
          ]
        },
        "media-design": {
          "summary": "Visual, audio, video, and creative asset generation.",
          "skill_examples": [
            "canvas-design",
            "fal-ai-media",
            "video-editing",
            "videodb",
            "vision-analysis"
          ]
        }
      }
    },
    "domain": {
      "label": "Domain",
      "summary": "Industry-specific vertical skills where domain language matters as much as implementation technique.",
      "category_bias": [
        "deep",
        "writing"
      ],
      "subtrees": {
        "healthcare": {
          "summary": "Healthcare workflows, safety, privacy, and CDSS/EMR support.",
          "skill_examples": [
            "healthcare-cdss-patterns",
            "healthcare-emr-patterns",
            "healthcare-phi-compliance",
            "healthcare-eval-harness",
            "hipaa-compliance"
          ]
        },
        "finance-billing": {
          "summary": "Billing, customer revenue operations, and investor-facing materials.",
          "skill_examples": [
            "finance-billing-ops",
            "customer-billing-ops",
            "investor-materials",
            "investor-outreach",
            "x-api"
          ]
        },
        "ops-industry": {
          "summary": "Logistics, procurement, planning, manufacturing, and quality operations.",
          "skill_examples": [
            "inventory-demand-planning",
            "production-scheduling",
            "quality-nonconformance",
            "carrier-relationship-management",
            "customs-trade-compliance"
          ]
        }
      }
    }
  },
  "classification_policy": {
    "primary_axis": "job_to_be_done",
    "secondary_axis": "technical_domain",
    "notes": [
      "OMO categories are execution/model-routing hints, not the taxonomy itself.",
      "Domain skills should be selected from activation signals and tags, not bulk auto-loaded from category alone.",
      "This tree is intentionally coarse at the top level to remain maintainable around a ~200-skill library size."
    ]
  },
  "overlap_policies": [
    {
      "group": "continuous-learning",
      "canonical": "continuous-learning-v2",
      "others": [
        "continuous-learning"
      ],
      "policy": "prefer_canonical"
    },
    {
      "group": "verification",
      "canonical": "verification",
      "others": [
        "verification-loop"
      ],
      "policy": "use_wrapper_only_for_orchestration"
    },
    {
      "group": "code-review",
      "canonical": "code-review",
      "others": [
        "code-review-expert"
      ],
      "policy": "prefer_general_first_then_expert_for_deeper_review"
    },
    {
      "group": "research-stack",
      "canonical": "research-ops",
      "others": [
        "deep-research",
        "exa-search",
        "search-first"
      ],
      "policy": "use_canonical_as_operator_workflow"
    },
    {
      "group": "flutter-stack",
      "canonical": "flutter-dev",
      "others": [
        "dart-flutter-patterns",
        "flutter-dart-code-review"
      ],
      "policy": "split_dev_patterns_review_by_intent"
    },
    {
      "group": "frontend-stack",
      "canonical": "frontend-patterns",
      "others": [
        "frontend-design",
        "frontend-dev"
      ],
      "policy": "patterns_first_design_for_visual_quality_media_variant_only_when_needed"
    }
  ]
}
