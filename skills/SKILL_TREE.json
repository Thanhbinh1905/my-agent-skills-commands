    },
    "operate": {
      "label": "Operate",
      "summary": "Execution workflows, git/GitHub operations, deployments, and workspace tooling.",
      "category_bias": [
        "quick",
        "unspecified-low"
      ],
      "subtrees": {
        "git-workflow": {
          "summary": "Git, GitHub, and project-flow operations.",
          "skill_examples": [
            "git",
            "git-workflow",
            "github-ops",
            "project-flow-ops",
            "jira-integration"
          ]
        },
        "runtime-ops": {
          "summary": "Terminal, deployment, notification, and workspace execution surfaces.",
          "skill_examples": [
            "terminal-ops",
            "deployment-patterns",
            "docker-patterns",
            "messages-ops",
            "email-ops"
          ]
        },
        "workspace-ops": {
          "summary": "Workspace, knowledge, and operator workflow support.",
          "skill_examples": [
            "workspace-surface-audit",
            "google-workspace-ops",
            "unified-notifications-ops",
            "automation-audit-ops",
            "ck"
          ]
        }
      }
    },
    "agent": {
      "label": "Agent",
      "summary": "Agent construction, orchestration, evaluation, memory, and autonomous execution.",
      "category_bias": [
        "ultrabrain",
        "deep"
      ],
      "subtrees": {
        "construction": {
          "summary": "Agent harnesses, action-space design, and skill-aware orchestration.",
          "skill_examples": [
            "agent-harness-construction",
            "agentic-engineering",
            "autonomous-agent-harness",
            "autonomous-loops",
            "team-builder"
          ]
        },
        "evaluation": {
          "summary": "Agent evaluation, introspection, and compliance verification.",
          "skill_examples": [
            "agent-eval",
